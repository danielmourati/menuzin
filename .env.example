# Configurações do Mercado Pago para Teste de Sandbox
# Substitua os valores abaixo pelas suas credenciais de sandbox do Mercado Pago
# Encontre em: Painel do Mercado Pago -> Suas Integrações -> Suas Aplicações -> Credenciais de Teste

TEST_MP_PUBLIC_KEY=TEST-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
TEST_MP_ACCESS_TOKEN=TEST-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Opcional: Se for conectar ao banco de dados Supabase
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
TOKEN_ENCRYPTION_KEY=sua_chave_de_criptografia_aqui
